# whisper-ollama-enricher configuration
# Copy to ~/.config/whisper-ollama-enricher/.env and fill in required values

# ── Required ────────────────────────────────────────────────────────────────

# Folder to watch for incoming transcripts (produced by local-whisper-obsidian)
INBOX_PATH=

# Obsidian vault root
VAULT_PATH=

# ── Optional ────────────────────────────────────────────────────────────────

# Where to write enriched notes (default: $VAULT_PATH/1_enriched)
OUTPUT_PATH=

# Ollama endpoint — examples:
#   http://localhost:11434        native on same host
#   http://172.17.0.1:11434      Docker on same host
#   http://192.168.1.50:11434    another machine in LAN
OLLAMA_BASE_URL=http://localhost:11434

# Model used for enrichment
# Minimum viable: gemma3:1b (4 GB RAM total)
# Recommended:    mistral   (8 GB RAM)
OLLAMA_MODEL=mistral

# Seconds before Ollama call times out
OLLAMA_TIMEOUT=60

# Retry interval in seconds — how often to retry files when Ollama was unavailable
RETRY_INTERVAL=30

# Custom system prompt for Ollama enrichment
# Leave empty to use built-in default prompt
# Accepts: file path (e.g. /home/user/.config/whisper-ollama-enricher/prompt.txt)
#          or inline string
OLLAMA_SYSTEM_PROMPT=

# Obsidian Local REST API (optional — leave empty for direct file write)
OBSIDIAN_REST_URL=http://127.0.0.1:27124
OBSIDIAN_API_KEY=

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO