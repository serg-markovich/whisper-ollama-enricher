# ── Required ─────────────────────────────────────────────────────────────────
INBOX_PATH=
VAULT_PATH=

# ── Output ───────────────────────────────────────────────────────────────────
OUTPUT_PATH=

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=60

# ── Obsidian REST API (leave empty = direct file write) ───────────────────────
OBSIDIAN_REST_URL=http://127.0.0.1:27124
OBSIDIAN_API_KEY=

# ── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
